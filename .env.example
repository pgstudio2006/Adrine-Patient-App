# Patient app — local development

# Platform APIs (required when NEXT_PUBLIC_PLATFORM_RUNTIME=true)
NEXT_PUBLIC_KERNEL_API_URL=http://localhost:3001
NEXT_PUBLIC_DOMAIN_API_URL=http://localhost:3002

# Dev tenant (matches hospital-os / kernel seed)
NEXT_PUBLIC_DEV_TENANT_ID=tenant_dev

# --- Choose one profile ---
# Demo on collaborator PC (no backend): NEXT_PUBLIC_PLATFORM_RUNTIME=false
# Live local stack (kernel + domain on same PC): NEXT_PUBLIC_PLATFORM_RUNTIME=true
NEXT_PUBLIC_PLATFORM_RUNTIME=true

# Optional: pin a known patient UUID instead of name-based resolve/create
# NEXT_PUBLIC_DEV_PATIENT_ID=
